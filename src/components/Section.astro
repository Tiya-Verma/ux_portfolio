---
interface Props {
  label: string;
  title?: string;
}
const { label, title } = Astro.props;
---

<section class="border-t border-rule pt-8 md:pt-10 pb-10 md:pb-14">
  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-3">
      <div class="text-[13px] uppercase tracking-[0.14em] font-medium text-soft">
        {label}
      </div>
      {
        title && (
          <h3 class="mt-1 text-[16px] font-medium text-body">{title}</h3>
        )
      }
    </div>
    <div class="col-span-12 md:col-span-9">
      <slot />
    </div>
  </div>
</section>
