---
interface Props {
  company: string;
  year: string;
  blurb: string;
  href?: string;
}

const { company, year, blurb, href = "#" } = Astro.props;
---

<a
  href={href}
  class="group block border-t border-rule py-7 md:py-8 transition-colors"
>
  <div class="flex items-start gap-6 md:gap-10">
    <div class="shrink-0 w-[120px] md:w-[160px]">
      <div
        class="text-[20px] md:text-[22px] font-medium text-[#374151] group-hover:text-hover transition-colors duration-200 tracking-tightish"
      >
        {company}
      </div>
      <div class="mt-1 text-[14px] text-ghost tabular-nums">{year}</div>
    </div>
    <div class="flex-1 min-w-0">
      <p
        class="text-[18px] md:text-[19px] leading-[1.4] text-soft group-hover:text-body transition-colors duration-200 max-w-xl"
      >
        {blurb}
        <span
          class="inline-block ml-0 opacity-0 group-hover:opacity-100 group-hover:ml-1.5 transition-all duration-200 ease-out text-accent"
          aria-hidden="true">↗</span
        >
      </p>
    </div>
  </div>
</a>
