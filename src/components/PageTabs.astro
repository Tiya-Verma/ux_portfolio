---
const path = Astro.url.pathname;
const isWork = path === "/" || path === "";
const isAbout = path.startsWith("/about");

const tab = (active: boolean) =>
  `px-4 py-2 rounded-full transition-colors duration-150 ${
    active ? "bg-[#eef0f3] text-ink" : "text-soft hover:text-body"
  }`;
---

<nav class="flex items-center gap-1.5 text-[18px] font-medium">
  <a href="/" class={tab(isWork)}>Work</a>
  <a href="/about" class={tab(isAbout)}>About</a>
</nav>
