---
import Layout from "../layouts/Layout.astro";
import AboutSidebar from "../components/AboutSidebar.astro";

const path = Astro.url.pathname;
const isWork = path === "/" || path === "";
const isAbout = path.startsWith("/about");
---

<Layout title="about — tiya verma">
  <div class="px-6 md:px-12 pt-10 md:pt-16 pb-16 md:pb-24">
    <div class="max-w-7xl mx-auto">
      <!-- top banner: name, tagline, tabs -->
      <header>
        <h1
          class="text-[44px] md:text-[56px] leading-[1.05] font-semibold tracking-tightish text-[#334155]"
        >
          tiya verma
        </h1>
        <p
          class="mt-4 text-[20px] md:text-[22px] leading-[1.45] font-normal text-soft tracking-tightish"
        >
          Product, design, &lt;dev&gt;,<br />& everything in between.
        </p>

        <nav class="mt-8 flex items-center gap-1 text-[17px] font-medium">
          <a
            href="/"
            class={`px-4 py-2 rounded-full transition-colors duration-150 ${
              isWork ? "bg-[#eef0f3] text-ink" : "text-soft hover:text-body"
            }`}
          >
            Work
          </a>
          <a
            href="/about"
            class={`px-4 py-2 rounded-full transition-colors duration-150 ${
              isAbout ? "bg-[#eef0f3] text-ink" : "text-soft hover:text-body"
            }`}
          >
            About
          </a>
        </nav>
      </header>

      <hr class="mt-6 border-t border-rule" />

      <div
        class="mt-10 lg:mt-14 grid grid-cols-1 lg:grid-cols-[180px_400px_1fr] gap-10 lg:gap-14"
      >
        <!-- left: section nav (sticky on desktop) -->
        <div class="lg:sticky lg:top-12 self-start">
          <AboutSidebar active="hi" />
        </div>

        <!-- middle: scattered photo cluster (static, scrolls with content) -->
        <div class="self-start hidden lg:block">
          <div class="flex flex-col items-center gap-6">
            <!-- main portrait as a polaroid, centered -->
            <div
              class="bg-white p-3 pb-12 shadow-[0_20px_45px_-18px_rgba(15,23,42,0.35)] -rotate-1"
            >
              <img
                src="/photo-main.jpg"
                alt=""
                class="block w-[220px] h-[220px] object-cover"
                onerror="this.style.background='linear-gradient(135deg,#1f2937,#475569)';this.removeAttribute('src');"
              />
            </div>

            <!-- bottom row: 3 photos in a row under the polaroid, with subtle tilts -->
            <div class="flex items-center justify-center gap-4">
              <img
                src="/photo-1.jpg"
                alt=""
                class="w-[88px] h-[72px] object-cover rounded-md shadow-[0_14px_30px_-12px_rgba(15,23,42,0.3)] -rotate-[6deg]"
                onerror="this.style.background='linear-gradient(135deg,#bae6fd,#a5b4fc)';this.removeAttribute('src');"
              />
              <img
                src="/photo-2.jpg"
                alt=""
                class="w-[88px] h-[72px] object-cover rounded-md shadow-[0_14px_30px_-12px_rgba(15,23,42,0.3)] rotate-[2deg]"
                onerror="this.style.background='linear-gradient(135deg,#fecdd3,#f9a8d4)';this.removeAttribute('src');"
              />
              <img
                src="/photo-3.jpg"
                alt=""
                class="w-[88px] h-[72px] object-cover rounded-md shadow-[0_14px_30px_-12px_rgba(15,23,42,0.3)] rotate-[6deg]"
                onerror="this.style.background='linear-gradient(135deg,#c4b5fd,#c084fc)';this.removeAttribute('src');"
              />
            </div>
          </div>
        </div>

      <!-- right: content -->
      <div class="max-w-2xl">
        <section id="hi" class="pt-2 pb-14 scroll-mt-20">
          <h2
            class="text-[28px] md:text-[34px] font-semibold text-[#334155] tracking-tightish"
          >
            Hi, I'm Tiya!
          </h2>

          <!-- meta line: location + education -->
          <div
            class="mt-5 flex flex-wrap items-center gap-x-7 gap-y-2 text-[15.5px] text-soft"
          >
            <div class="flex items-center gap-2">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path
                  d="M12 22s-7-7.58-7-13a7 7 0 0 1 14 0c0 5.42-7 13-7 13z"
                ></path>
                <circle cx="12" cy="9" r="2.5"></circle>
              </svg>
              <span>Vancouver</span>
            </div>
            <div class="flex items-center gap-2">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M22 10 12 5 2 10l10 5 10-5z"></path>
                <path d="M6 12v5a6 6 0 0 0 12 0v-5"></path>
              </svg>
              <span>B.Sc. Computer Science @ UBC</span>
            </div>
          </div>

          <p class="mt-6 text-[17px] leading-[1.7] text-body">
            I love design, technology, &amp; the small moments where the two
            quietly come together to make something feel human.
          </p>
          <p class="mt-4 text-[17px] leading-[1.7] text-body">
            I view myself as a creative thinker. I am drawn to design that highlights human experiences and feels purposeful. For me, there is joy in the constant pursuit of work that aligns who I am with what I create.
          </p>
          <p class="mt-4 text-[17px] leading-[1.7] text-body">
            3 words to describe me: <em>quietly curious, always cooking</em>.
          </p>
        </section>

        <section
          id="experience"
          class="border-t border-rule pt-10 pb-14 scroll-mt-20"
        >
          <h2
            class="text-[24px] md:text-[26px] font-semibold text-[#334155] tracking-tightish"
          >
            Experience
          </h2>
          <ol class="mt-6 space-y-6">
            <li class="flex items-baseline justify-between gap-6">
              <div>
                <div class="text-[16px] font-medium text-ink">
                  Product FrontEnd Developer · 
                  <span class="text-muted font-normal">UBC MINT MOSS </span>
                </div>
                <p class="mt-1 text-[14.5px] text-soft max-w-lg">
                  Making brain signal processing feel less like a lab and more like a tool built for people.
                </p>
              </div>
              <span class="text-[13px] text-ghost tabular-nums shrink-0">
                2025 — now
              </span>
            </li>
            <li class="flex items-baseline justify-between gap-6">
              <div>
                <div class="text-[16px] font-medium text-ink">
                   Marketing Coordinator ·
                  <span class="text-muted font-normal">youCode</span>
                </div>
                <p class="mt-1 text-[14.5px] text-soft max-w-lg">
                  Led the engagement and storytelling behind one of UBC's most community-driven hackathons.
                </p>
              </div>
              <span class="text-[13px] text-ghost tabular-nums shrink-0">
                2026
              </span>
            </li>
            <li class="flex items-baseline justify-between gap-6">
              <div>
                <div class="text-[16px] font-medium text-ink">
                  FrontEnd Web Developer ·
                  <span class="text-muted font-normal">Nomadly</span>
                </div>
                <p class="mt-1 text-[14.5px] text-soft max-w-lg">
                  Brought wanderlust to the browser, one interactive destination at a time.
                </p>
              </div>
              <span class="text-[13px] text-ghost tabular-nums shrink-0">
                2025
              </span>
            </li>
          </ol>
        </section>

        <section
          id="community"
          class="border-t border-rule pt-10 pb-14 scroll-mt-20"
        >
          <h2
            class="text-[24px] md:text-[26px] font-semibold text-[#334155] tracking-tightish"
          >
            Community
          </h2>
          <ul class="mt-6 space-y-5 text-[15.5px] text-body">
            <li class="flex items-center gap-5">
              <div
                class="shrink-0 w-14 h-14 rounded-full bg-[#eef0f3] flex items-center justify-center overflow-hidden"
              >
                <img
                  src="/logo-wics.jpg"
                  alt="UBC Women in CS logo"
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none';"
                />
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-[17px] font-medium text-ink">
                  UBC Women in CS
                </div>
                <div class="text-[14.5px] text-soft">
                  youCode Marketing and Engagement Coordinator
                </div>
              </div>
            </li>
            <li class="flex items-center gap-5">
              <div
                class="shrink-0 w-14 h-14 rounded-full bg-[#eef0f3] flex items-center justify-center overflow-hidden"
              >
                <img
                  src="/logo-mint.png"
                  alt="UBC MINT logo"
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none';"
                />
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-[17px] font-medium text-ink">UBC MINT</div>
                <div class="text-[14.5px] text-soft">
                  SWE Product Front-End Developer
                </div>
              </div>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </div>
</Layout>
