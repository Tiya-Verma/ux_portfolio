---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
---

<Layout title={`${project.company} — tiya verma`}>
  <main>
    <!-- back link -->
    <div class="px-6 md:px-12 pt-6 md:pt-8">
      <div class="max-w-6xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-[14px] text-soft hover:text-ink transition-colors"
        >
          <span aria-hidden="true">←</span>
          back to work
        </a>
      </div>
    </div>

    <!-- big hero band -->
    <section class="px-6 md:px-12 mt-6 md:mt-8">
      <div class="max-w-6xl mx-auto">
        <div
          class="relative w-full aspect-[16/9] md:aspect-[16/8] rounded-xl overflow-hidden"
          style={`background:${project.bg}`}
        >
          <div
            class="absolute inset-0 flex items-center justify-center"
            set:html={project.inner}
          />
        </div>
      </div>
    </section>

    <!-- title + meta band -->
    <section class="px-6 md:px-12 mt-10 md:mt-14">
      <div class="max-w-6xl mx-auto">
        <h1
          class="text-[40px] md:text-[56px] leading-[1.05] font-semibold tracking-tightish text-[#1f2937]"
        >
          {project.company}
        </h1>

        <div
          class="mt-10 md:mt-12 grid grid-cols-1 md:grid-cols-2 gap-y-10 gap-x-10 max-w-4xl"
        >
          <div>
            <div class="text-[14px] text-soft lowercase">role</div>
            <div class="mt-2 text-[15.5px] text-body">{project.role}</div>
          </div>
          <div>
            <div class="text-[14px] text-soft lowercase">team</div>
            <div class="mt-2 text-[15.5px] text-body">{project.team}</div>
          </div>
          <div>
            <div class="text-[14px] text-soft lowercase">timeline</div>
            <div class="mt-2 text-[15.5px] text-body">{project.timeline}</div>
          </div>
          <div>
            <div class="text-[14px] text-soft lowercase">skills</div>
            <div class="mt-2 text-[15.5px] text-body">
              {project.skills.join(", ")}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- overview -->
    <section class="px-6 md:px-12 mt-20 md:mt-28">
      <div class="max-w-6xl mx-auto">
        <div class="text-[14px] text-soft lowercase">overview</div>
        <h2
          class="mt-3 text-[22px] md:text-[26px] leading-[1.35] text-[#1f2937] tracking-tightish max-w-5xl"
        >
          {project.tagline}
        </h2>
        <div
          class="mt-8 space-y-5 text-[16.5px] md:text-[17px] leading-[1.7] text-body"
        >
          {project.overview.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </section>

    <!-- problem -->
    <section class="px-6 md:px-12 mt-20 md:mt-24">
      <div class="max-w-6xl mx-auto">
        <div class="text-[14px] text-soft lowercase">problem</div>
        <ol
          class="mt-6 space-y-4 text-[16.5px] md:text-[17px] leading-[1.7] text-body list-decimal pl-5 marker:text-ghost marker:font-medium"
        >
          {project.problem.map((p) => <li>{p}</li>)}
        </ol>
      </div>
    </section>

    <!-- reflections -->
    <section class="px-6 md:px-12 mt-20 md:mt-24 pb-20 md:pb-28">
      <div class="max-w-6xl mx-auto">
        <div class="text-[14px] text-soft lowercase">reflections</div>
        <div class="mt-6 space-y-10">
          {
            project.reflections.map((r) => (
              <div>
                <h3 class="text-[19px] md:text-[20px] font-medium text-[#1f2937]">
                  {r.heading}
                </h3>
                <p class="mt-3 text-[16.5px] md:text-[17px] leading-[1.7] text-body">
                  {r.body}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
